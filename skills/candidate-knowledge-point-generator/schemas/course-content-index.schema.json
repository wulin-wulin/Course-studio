{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:course-content-index:1.0",
  "title": "Course Content Planning Index",
  "description": "CKDS 发布前、不含知识簇与布局字段的课程内容索引。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "courseId",
    "points"
  ],
  "properties": {
    "schema_version": {
      "const": "course-content-index/1.0"
    },
    "courseId": {
      "$ref": "#/$defs/kebabId"
    },
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/indexPoint"
      }
    }
  },
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "indexPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "shortSummary",
        "difficulty",
        "importance",
        "keyTerms"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/kebabId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "shortSummary": {
          "type": "string",
          "minLength": 30,
          "maxLength": 100
        },
        "difficulty": {
          "enum": [
            "基础",
            "中等",
            "进阶"
          ]
        },
        "importance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "keyTerms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

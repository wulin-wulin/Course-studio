{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:candidate-points:1.0",
  "title": "Candidate Knowledge Point Pool",
  "description": "学科知识图谱在聚类与关系构建之前使用的扁平候选知识点池。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "generation",
    "sources",
    "candidates",
    "reviewQueue"
  ],
  "properties": {
    "schema_version": {
      "const": "candidate-points/1.0"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "generation": {
      "$ref": "#/$defs/generation"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "reviewQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewItem"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "generation": {
            "properties": {
              "evidenceMode": {
                "const": "researched"
              }
            },
            "required": [
              "evidenceMode"
            ]
          }
        },
        "required": [
          "generation"
        ]
      },
      "then": {
        "properties": {
          "sources": {
            "minItems": 3
          },
          "candidates": {
            "items": {
              "properties": {
                "sourceRefs": {
                  "minItems": 1
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "generation": {
            "properties": {
              "evidenceMode": {
                "const": "model-only"
              }
            },
            "required": [
              "evidenceMode"
            ]
          }
        },
        "required": [
          "generation"
        ]
      },
      "then": {
        "properties": {
          "sources": {
            "maxItems": 0
          },
          "candidates": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/candidate"
                },
                {
                  "properties": {
                    "sourceRefs": {
                      "maxItems": 0
                    },
                    "confidence": {
                      "maximum": 0.6
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input",
        "normalizedTitle",
        "inputType",
        "language",
        "audience",
        "depth",
        "scope",
        "exclusions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/kebabId"
        },
        "input": {
          "type": "string",
          "minLength": 1
        },
        "normalizedTitle": {
          "type": "string",
          "minLength": 1
        },
        "inputType": {
          "enum": [
            "course",
            "domain"
          ]
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "depth": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "exclusions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceMode",
        "generatedAt",
        "candidateCount"
      ],
      "properties": {
        "evidenceMode": {
          "enum": [
            "researched",
            "model-only"
          ]
        },
        "generatedAt": {
          "type": "string",
          "format": "date"
        },
        "candidateCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "locator",
        "accessedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^src-[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "type": {
          "enum": [
            "official-standard",
            "curriculum",
            "textbook",
            "university-course",
            "professional-standard",
            "handbook",
            "survey",
            "reference"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "accessedAt": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "aliases",
        "kind",
        "shortSummary",
        "difficulty",
        "importance",
        "keyTerms",
        "sourceRefs",
        "confidence",
        "scopeStatus"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/kebabId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "kind": {
          "enum": [
            "concept",
            "method",
            "theorem",
            "model",
            "algorithm",
            "task",
            "metric",
            "phenomenon"
          ]
        },
        "shortSummary": {
          "type": "string",
          "minLength": 30,
          "maxLength": 100
        },
        "difficulty": {
          "enum": [
            "基础",
            "中等",
            "进阶"
          ]
        },
        "importance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.01
        },
        "keyTerms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^src-[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.01
        },
        "scopeStatus": {
          "enum": [
            "core",
            "boundary",
            "needs-review"
          ]
        }
      }
    },
    "reviewItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term",
        "issue",
        "reason",
        "suggestedAction"
      ],
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1
        },
        "issue": {
          "enum": [
            "scope-ambiguity",
            "granularity",
            "synonym",
            "naming",
            "insufficient-evidence"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "suggestedAction": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

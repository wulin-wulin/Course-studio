{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:clustered-graph:2.0",
  "title": "Clustered Knowledge Graph",
  "description": "上游 v2 课程内容中间包经聚类与关系构建后的产物：在透传全部知识点内容的基础上，追加簇归属（clusterIds，首个为主簇）、层级角色（role）与横向关联（related），并透传/优化 prerequisites（DAG）。不含 pos/scale/polygon 等布局字段。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "generation",
    "clusters",
    "points"
  ],
  "properties": {
    "schema_version": { "const": "clustered-graph/2.0" },
    "subject": { "$ref": "#/$defs/subject" },
    "generation": { "$ref": "#/$defs/generation" },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/cluster" }
    },
    "points": {
      "type": "array",
      "items": { "$ref": "#/$defs/point" }
    }
  },
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "subject": {
      "description": "透传自上游 v2 generation/manifest.json 的 subject（含 outcomes）。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input",
        "normalizedTitle",
        "inputType",
        "language",
        "audience",
        "depth",
        "scope",
        "exclusions",
        "outcomes"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "input": { "type": "string", "minLength": 1 },
        "normalizedTitle": { "type": "string", "minLength": 1 },
        "inputType": { "enum": ["course", "domain"] },
        "language": { "type": "string", "minLength": 2 },
        "audience": { "type": "string", "minLength": 1 },
        "depth": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "exclusions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "outcomes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generatedAt",
        "sourceCourseId",
        "pointCount",
        "clusterCount",
        "brokenCycleEdges",
        "refinedPrerequisiteEdges"
      ],
      "properties": {
        "generatedAt": { "type": "string", "format": "date" },
        "sourceCourseId": { "$ref": "#/$defs/kebabId" },
        "pointCount": { "type": "integer", "minimum": 0 },
        "clusterCount": { "type": "integer", "minimum": 0 },
        "brokenCycleEdges": {
          "description": "为保证无环而移除的反向依赖边，供审计。",
          "type": "array",
          "items": { "$ref": "#/$defs/brokenEdge" }
        },
        "refinedPrerequisiteEdges": {
          "description": "对 v2 prerequisites 主动优化（补漏/去冗余/纠向）的逐条记录，供审计。",
          "type": "array",
          "items": { "$ref": "#/$defs/refinedEdge" }
        }
      }
    },
    "brokenEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "reason"],
      "properties": {
        "from": { "$ref": "#/$defs/kebabId" },
        "to": { "$ref": "#/$defs/kebabId" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "refinedEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "from", "to", "reason"],
      "properties": {
        "op": { "enum": ["add", "remove"] },
        "from": { "$ref": "#/$defs/kebabId" },
        "to": { "$ref": "#/$defs/kebabId" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "subtitle", "description", "order"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 0 },
        "accent": { "$ref": "#/$defs/hexColor" },
        "soft": { "$ref": "#/$defs/hexColor" },
        "dark": { "$ref": "#/$defs/hexColor" }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "shortSummary",
        "coreIdea",
        "principles",
        "keyTerms",
        "applications",
        "aliases",
        "intuition",
        "misconceptions",
        "qa",
        "animationType",
        "difficulty",
        "importance",
        "prerequisites",
        "clusterIds",
        "role",
        "related"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "title": { "type": "string", "minLength": 1 },
        "shortSummary": { "type": "string", "minLength": 30, "maxLength": 100 },
        "coreIdea": { "type": "string", "minLength": 1 },
        "principles": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "formula": { "type": "string", "minLength": 1 },
        "keyTerms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "comparisons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "applications": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "intuition": { "type": "string", "minLength": 1 },
        "misconceptions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "history": { "type": "string", "minLength": 1 },
        "yearIntroduced": { "type": "integer" },
        "prosCons": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pros", "cons"],
          "properties": {
            "pros": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "cons": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "qa": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["q", "a"],
            "properties": {
              "q": { "type": "string", "minLength": 1 },
              "a": { "type": "string", "minLength": 1 }
            }
          }
        },
        "visualType": {
          "enum": [
            "foundation", "timeline", "search", "logic", "knowledgeGraph",
            "learning", "decisionTree", "bayes", "neuralNetwork", "gradient",
            "attention", "transformer", "vision", "agentLoop", "diffusion", "ethics"
          ]
        },
        "visualSuggestion": { "type": "string", "minLength": 1 },
        "animationType": { "type": "string", "pattern": "^(?:none|[a-z][A-Za-z0-9]*)$" },
        "animationSuggestion": { "type": "string", "minLength": 1 },
        "difficulty": { "enum": ["基础", "中等", "进阶"] },
        "importance": { "type": "number", "minimum": 0, "maximum": 1 },
        "prerequisites": {
          "description": "有向前置依赖（透传 v2 并可优化）；元素为本图中其他点 id；无悬空、无自环，全局构成 DAG。",
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebabId" }
        },
        "clusterIds": {
          "description": "簇归属，首个为主簇（供布局/着色）；每个元素必须命中某簇。",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebabId" }
        },
        "role": { "enum": ["trunk", "branch", "leaf"] },
        "related": {
          "description": "无向横向关联，元素为本图中其他点 id；不参与 DAG 校验。",
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebabId" }
        }
      },
      "dependentRequired": {
        "visualType": ["visualSuggestion"],
        "visualSuggestion": ["visualType"],
        "animationSuggestion": ["animationType"]
      },
      "allOf": [
        {
          "if": {
            "properties": { "animationType": { "const": "none" } },
            "required": ["animationType"]
          },
          "then": { "not": { "required": ["animationSuggestion"] } },
          "else": { "required": ["animationSuggestion"] }
        }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:animation-request:1.0",
  "title": "Knowledge Point Animation Request",
  "description": "逐知识点提交的机制动画必要性判断。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pointId",
    "needed",
    "rationale"
  ],
  "properties": {
    "schema_version": {
      "const": "animation-request/1.0"
    },
    "pointId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "needed": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "mechanism": {
      "$ref": "#/$defs/mechanism"
    },
    "suggestion": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "needed": {
            "const": true
          }
        },
        "required": [
          "needed"
        ]
      },
      "then": {
        "required": [
          "mechanism",
          "suggestion"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "mechanism"
              ]
            },
            {
              "required": [
                "suggestion"
              ]
            }
          ]
        }
      }
    }
  ],
  "$defs": {
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputs",
        "changingState",
        "transitionRule",
        "terminalState",
        "replayMode"
      ],
      "properties": {
        "inputs": {
          "type": "string",
          "minLength": 1
        },
        "changingState": {
          "type": "string",
          "minLength": 1
        },
        "transitionRule": {
          "type": "string",
          "minLength": 1
        },
        "terminalState": {
          "type": "string",
          "minLength": 1
        },
        "replayMode": {
          "enum": [
            "restart",
            "both",
            "loop"
          ]
        }
      }
    }
  }
}

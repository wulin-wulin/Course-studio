{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:course-content-point:1.0",
  "title": "Course Content Knowledge Point",
  "description": "不含知识簇和布局字段的完整知识点详情。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "shortSummary",
    "coreIdea",
    "principles",
    "keyTerms",
    "applications",
    "aliases",
    "intuition",
    "misconceptions",
    "qa",
    "animationType",
    "difficulty",
    "importance",
    "prerequisites"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/kebabId"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "shortSummary": {
      "type": "string",
      "minLength": 30,
      "maxLength": 100
    },
    "coreIdea": {
      "type": "string",
      "minLength": 1
    },
    "principles": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "formula": {
      "type": "string",
      "minLength": 1
    },
    "keyTerms": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "comparisons": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applications": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "aliases": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "intuition": {
      "type": "string",
      "minLength": 1
    },
    "misconceptions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "history": {
      "type": "string",
      "minLength": 1
    },
    "yearIntroduced": {
      "type": "integer"
    },
    "prosCons": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pros",
        "cons"
      ],
      "properties": {
        "pros": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "qa": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "q",
          "a"
        ],
        "properties": {
          "q": {
            "type": "string",
            "minLength": 1
          },
          "a": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "visualType": {
      "enum": [
        "foundation",
        "timeline",
        "search",
        "logic",
        "knowledgeGraph",
        "learning",
        "decisionTree",
        "bayes",
        "neuralNetwork",
        "gradient",
        "attention",
        "transformer",
        "vision",
        "agentLoop",
        "diffusion",
        "ethics"
      ]
    },
    "visualSuggestion": {
      "type": "string",
      "minLength": 1
    },
    "animationType": {
      "type": "string",
      "pattern": "^(?:none|[a-z][A-Za-z0-9]*)$"
    },
    "animationSuggestion": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "enum": [
        "基础",
        "中等",
        "进阶"
      ]
    },
    "importance": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "prerequisites": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/kebabId"
      }
    }
  },
  "dependentRequired": {
    "visualType": [
      "visualSuggestion"
    ],
    "visualSuggestion": [
      "visualType"
    ],
    "animationSuggestion": [
      "animationType"
    ]
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "animationType": {
            "const": "none"
          }
        },
        "required": [
          "animationType"
        ]
      },
      "then": {
        "not": {
          "required": [
            "animationSuggestion"
          ]
        }
      },
      "else": {
        "required": [
          "animationSuggestion"
        ]
      }
    }
  ],
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}

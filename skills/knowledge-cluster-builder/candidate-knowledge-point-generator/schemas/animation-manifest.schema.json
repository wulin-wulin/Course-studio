{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:course-content-animations:1.0",
  "title": "Course Content Animation Manifest",
  "description": "按真实机制归并后的教学动画类型与知识点绑定。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "animations"
  ],
  "properties": {
    "schema_version": {
      "const": "course-content-animations/1.0"
    },
    "animations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/animation"
      }
    }
  },
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputs",
        "changingState",
        "transitionRule",
        "terminalState",
        "replayMode"
      ],
      "properties": {
        "inputs": {
          "type": "string",
          "minLength": 1
        },
        "changingState": {
          "type": "string",
          "minLength": 1
        },
        "transitionRule": {
          "type": "string",
          "minLength": 1
        },
        "terminalState": {
          "type": "string",
          "minLength": 1
        },
        "replayMode": {
          "enum": [
            "restart",
            "both",
            "loop"
          ]
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pointId",
        "suggestion"
      ],
      "properties": {
        "pointId": {
          "$ref": "#/$defs/kebabId"
        },
        "suggestion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "component",
        "title",
        "mechanism",
        "bindings"
      ],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][A-Za-z0-9]*$",
          "not": {
            "const": "none"
          }
        },
        "component": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "mechanism": {
          "$ref": "#/$defs/mechanism"
        },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/binding"
          }
        }
      }
    }
  }
}

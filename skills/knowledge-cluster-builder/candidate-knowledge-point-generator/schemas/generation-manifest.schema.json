{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:course-content-generation:1.0",
  "title": "Course Content Generation Manifest",
  "description": "课程内容中间包的范围、来源、逐点证据和复核信息。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "generation",
    "sources",
    "pointEvidence",
    "reviewQueue"
  ],
  "properties": {
    "schema_version": {
      "const": "course-content-generation/1.0"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "generation": {
      "$ref": "#/$defs/generation"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "pointEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pointEvidence"
      }
    },
    "reviewQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewItem"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "generation": {
            "properties": {
              "evidenceMode": {
                "const": "researched"
              }
            },
            "required": [
              "evidenceMode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "sources": {
            "minItems": 3
          },
          "pointEvidence": {
            "items": {
              "properties": {
                "sourceRefs": {
                  "minItems": 1
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "generation": {
            "properties": {
              "evidenceMode": {
                "const": "model-only"
              }
            },
            "required": [
              "evidenceMode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "sources": {
            "maxItems": 0
          },
          "pointEvidence": {
            "items": {
              "properties": {
                "sourceRefs": {
                  "maxItems": 0
                },
                "confidence": {
                  "maximum": 0.6
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input",
        "normalizedTitle",
        "inputType",
        "language",
        "audience",
        "depth",
        "scope",
        "exclusions",
        "outcomes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/kebabId"
        },
        "input": {
          "type": "string",
          "minLength": 1
        },
        "normalizedTitle": {
          "type": "string",
          "minLength": 1
        },
        "inputType": {
          "enum": [
            "course",
            "domain"
          ]
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "depth": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "exclusions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceMode",
        "generatedAt",
        "pointCount"
      ],
      "properties": {
        "evidenceMode": {
          "enum": [
            "researched",
            "model-only"
          ]
        },
        "generatedAt": {
          "type": "string",
          "format": "date"
        },
        "pointCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "locator",
        "accessedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^src-[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "type": {
          "enum": [
            "official-standard",
            "curriculum",
            "textbook",
            "university-course",
            "professional-standard",
            "handbook",
            "survey",
            "reference"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "accessedAt": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "pointEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pointId",
        "title",
        "kind",
        "sourceRefs",
        "confidence",
        "scopeStatus"
      ],
      "properties": {
        "pointId": {
          "$ref": "#/$defs/kebabId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "concept",
            "method",
            "theorem",
            "model",
            "algorithm",
            "task",
            "metric",
            "phenomenon"
          ]
        },
        "sourceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^src-[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "scopeStatus": {
          "enum": [
            "core",
            "boundary",
            "needs-review"
          ]
        }
      }
    },
    "reviewItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term",
        "issue",
        "reason",
        "suggestedAction"
      ],
      "properties": {
        "pointId": {
          "$ref": "#/$defs/kebabId"
        },
        "term": {
          "type": "string",
          "minLength": 1
        },
        "issue": {
          "enum": [
            "scope-ambiguity",
            "granularity",
            "synonym",
            "naming",
            "insufficient-evidence"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "suggestedAction": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

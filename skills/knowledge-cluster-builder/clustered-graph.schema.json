{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-knowledge-forest:schema:clustered-graph:1.0",
  "title": "Clustered Knowledge Graph",
  "description": "候选知识点经聚类与关系构建后的中间产物：带簇归属、层级角色、前置依赖（DAG）与横向关联。位于候选点生成之后、CKDS 发布之前，不含 pos/scale/polygon 等布局字段。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "generation",
    "clusters",
    "points"
  ],
  "properties": {
    "schema_version": {
      "const": "clustered-graph/1.0"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "generation": {
      "$ref": "#/$defs/generation"
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cluster"
      }
    },
    "points": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/point"
      }
    }
  },
  "$defs": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "subject": {
      "description": "透传自上游 candidate-points 的课程/领域范围契约，保持可追溯。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input",
        "normalizedTitle",
        "inputType",
        "language",
        "audience",
        "depth",
        "scope",
        "exclusions"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "input": { "type": "string", "minLength": 1 },
        "normalizedTitle": { "type": "string", "minLength": 1 },
        "inputType": { "enum": ["course", "domain"] },
        "language": { "type": "string", "minLength": 2 },
        "audience": { "type": "string", "minLength": 1 },
        "depth": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "exclusions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generatedAt",
        "sourceSchema",
        "candidateCount",
        "clusterCount",
        "brokenCycleEdges"
      ],
      "properties": {
        "generatedAt": { "type": "string", "format": "date" },
        "sourceSchema": { "const": "candidate-points/1.0" },
        "candidateCount": { "type": "integer", "minimum": 0 },
        "clusterCount": { "type": "integer", "minimum": 0 },
        "brokenCycleEdges": {
          "description": "构建过程中为保证无环而移除的反向依赖边，供审计。",
          "type": "array",
          "items": { "$ref": "#/$defs/brokenEdge" }
        }
      }
    },
    "brokenEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "reason"],
      "properties": {
        "from": { "$ref": "#/$defs/kebabId" },
        "to": { "$ref": "#/$defs/kebabId" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "subtitle", "description", "order"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 0 },
        "accent": { "$ref": "#/$defs/hexColor" },
        "soft": { "$ref": "#/$defs/hexColor" },
        "dark": { "$ref": "#/$defs/hexColor" }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "clusterId",
        "role",
        "prerequisites",
        "related",
        "kind",
        "shortSummary",
        "difficulty",
        "importance",
        "keyTerms",
        "aliases"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "title": { "type": "string", "minLength": 1 },
        "clusterId": { "$ref": "#/$defs/kebabId" },
        "role": { "enum": ["trunk", "branch", "leaf"] },
        "prerequisites": {
          "description": "有向前置依赖，元素为本图中其他点的 id；必须无悬空、无自环，且全局构成 DAG。",
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebabId" }
        },
        "related": {
          "description": "无向横向关联，元素为本图中其他点的 id；不参与 DAG 校验。",
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebabId" }
        },
        "kind": {
          "enum": [
            "concept",
            "method",
            "theorem",
            "model",
            "algorithm",
            "task",
            "metric",
            "phenomenon"
          ]
        },
        "shortSummary": { "type": "string", "minLength": 1 },
        "difficulty": { "enum": ["基础", "中等", "进阶"] },
        "importance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.01
        },
        "keyTerms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
